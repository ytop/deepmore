TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"
DEEPSEEK_API_KEY="your_deepseek_api_key_here"
ALLOWED_USER_ID="your_telegram_user_id_here"  # set to 0 to allow all users
# DEEPSEEK_BASE_URL="https://api.deepseek.com/v1" # Optional override
DEEPSEEK_MODEL_BASE="deepseek-chat"
DEEPSEEK_MODEL_ULTRA="deepseek-reasoner"
WORKSPACE="/path/to/your/code"  # directory the agent is allowed to read/write
# AGENT_MAX_ITERATIONS=25  # Optional. Max tool-loop iterations per turn (1-1000). Default 25.

# ── Lark channel (optional) ──────────────────────────────────────────────────
# Create a Custom App at https://open.larksuite.com/app and enable the bot capability.
# Subscribe to the im.message.receive_v1 event and use long-connection (WebSocket) mode.
# LARK_APP_ID="cli_xxxxxxxxxxxx"
# LARK_APP_SECRET="your_lark_app_secret_here"
